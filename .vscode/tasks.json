{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Full Test Suite",
      "type": "shell",
      "command": "python -m pytest",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
