# ─── LLM Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=             # optional — platform.openai.com/api-keys
GOOGLE_API_KEY=             # optional — aistudio.google.com/app/apikey
GROQ_API_KEY=               # optional — console.groq.com/keys
MISTRAL_API_KEY=            # optional — console.mistral.ai
XAI_API_KEY=                # optional — console.x.ai

# ─── Agent Identity ────────────────────────────────────────────────────────────
AGENT_NAME=agent-1
AGENT_MODEL=claude-haiku-4-5    # default model (used when no tier is matched)
EMBEDDING_MODEL=text-embedding-3-small  # OpenAI model for semantic memory (requires OPENAI_API_KEY)

# ─── Model Tiers (dynamic routing) ────────────────────────────────────────────
# fast  → simple Q&A, greetings             (users can prefix /fast <message>)
# smart → code, research, multi-step tasks  (users can prefix /smart <message>)
# best  → complex reasoning, architecture   (users can prefix /best <message>)
#
# Anthropic (default):
MODEL_FAST=claude-haiku-4-5
MODEL_SMART=claude-sonnet-4-5
MODEL_BEST=claude-opus-4-5
# OpenAI alternative:
# MODEL_FAST=gpt-4o-mini
# MODEL_SMART=gpt-4o
# MODEL_BEST=o3
# Gemini alternative (top MCP tool-use benchmark as of 2026):
# MODEL_FAST=gemini-2.5-flash
# MODEL_SMART=gemini-2.5-pro
# MODEL_BEST=gemini-3.1-pro
# Groq (ultra-low latency, weaker on complex tasks — best suited for fast tier):
# MODEL_FAST=llama-3.3-70b-versatile
# Self-hosted via Ollama or vLLM (OpenAI-compatible — requires custom base URL in core.py):
# MODEL_FAST=ollama:llama3.3:latest

# ─── Extended Thinking ─────────────────────────────────────────────────────────
# Enables chain-of-thought reasoning. Supported providers and models:
#   Claude:  non-Haiku models (sonnet, opus) — streams as 🧠 in Discord
#   OpenAI:  o-series models (o1, o3, o4)    — sets reasoning_effort=high
#   Gemini:  2.5 Pro and newer               — sets thinking_budget
#   Groq:    reasoning-capable models (qwen-3-32b, etc.) — sets reasoning_format=parsed
# Thinking tokens are billed at output token rates (~5x input cost).
# Enable only when deep multi-step reasoning is explicitly needed.
THINKING_ENABLED=false
THINKING_BUDGET_TOKENS=1000

# ─── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=               # personal access token or fine-grained PAT (exported as GH_TOKEN for gh CLI)
                            # scopes needed: repo, read:org
GITHUB_USERNAME=            # your GitHub username (for git commits inside container)
GITHUB_SSH_KEY=/root/.ssh/agent_ed25519   # path inside container (auto-set by install.sh)
AGENT_REPO=                 # auto-set by install.sh: github_username/agent_name (the fork)

# ─── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_AGENT_CHANNEL_ID=   # numeric channel ID for this agent's private channel
DISCORD_BUS_CHANNEL_ID=     # #agent-bus (all agents)
DISCORD_COMMS_CHANNEL_ID=   # #agent-comms (structured A2A JSON)
DISCORD_GUILD_ID=            # numeric guild/server ID

# ─── Databases ─────────────────────────────────────────────────────────────────
SQLITE_PATH=/data/agent.db

# External PostgreSQL (optional) — auto-assembled by install.sh from PG_* vars below
POSTGRES_URL=               # postgresql+asyncpg://user:pass@host:port/db
PG_HOST=                    # e.g. 89.167.1.147
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=

# ─── MCP Servers ───────────────────────────────────────────────────────────────
BROWSER_MCP_URL=http://browser:3080/sse

# ─── Proxy & Browser Identity (optional) ───────────────────────────────────────
# Routes Playwright/Chromium through a residential proxy to avoid datacenter blocks.
# Option A — single URL (most providers):
PROXY_URL=                  # http://user:pass@host:port  or  socks5://user:pass@host:port
# Option B — split fields (some providers supply these separately):
PROXY_SERVER=               # host:port
PROXY_USERNAME=
PROXY_PASSWORD=
# Browser locale/timezone/geolocation — should match proxy exit country
BROWSER_LOCALE=en-US
BROWSER_TIMEZONE=America/New_York
BROWSER_GEO_LAT=40.7128
BROWSER_GEO_LON=-74.0060

# ─── Self-update ───────────────────────────────────────────────────────────────
DOCKER_RESTART_SELF=true    # allow agent to restart its own container
AGENT_CONTAINER_NAME=agent  # docker container name for self-restart

# ─── Retention & Cleanup ───────────────────────────────────────────────────────
# Cleanup runs automatically once per hour via heartbeat(). Tune per deployment.
RETENTION_CONVERSATIONS_DAYS=30   # delete conversations older than N days
RETENTION_TASKS_DAYS=90           # delete task log entries older than N days
RETENTION_MEMORY_FACTS_MAX=500    # keep at most N memory facts (oldest deleted first)
RETENTION_LESSONS_MAX=200         # keep at most N lessons (least-used deleted first)
RETENTION_AUDIT_LOG_DAYS=30       # delete Postgres audit_log entries older than N days
RETENTION_SHARED_TASKS_DAYS=14    # delete completed/failed shared tasks older than N days
RETENTION_SHARED_MEMORY_MAX=1000  # keep at most N shared_memory rows per agent

# ─── Paths (inside container) ─────────────────────────────────────────────────
WORKSPACE_PATH=/workspace
SKILLS_PATH=/app/agent/skills
IDENTITY_PATH=/app/agent/identity
